@model BAOCAO_369.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập Hệ thống EVN Premium";
    Layout = null; // Đăng nhập không cần xài Navbar chuẩn, nó là 1 Single Page rỗng
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        body { 
            background: linear-gradient(135deg, #003893 0%, #0056e0 100%); /* Trải nền xanh EVN chìm */
            display: flex; 
            align-items: center; 
            justify-content: center; 
            height: 100vh; 
            margin: 0; 
        }
        .login-card {
            background: white; 
            border-radius: 16px; 
            box-shadow: 0 20px 40px rgba(0,0,0,0.2); 
            padding: 3rem; 
            width: 100%; 
            max-width: 420px;
        }
        .login-logo {
            text-align: center; 
            margin-bottom: 2rem; 
            color: #003893;
        }
        .login-logo i { 
            font-size: 3.5rem; 
            margin-bottom: 1rem; 
            color: #F58220; /* Màu cam EVN Accent */
        }
        .login-logo h3 { 
            font-family: 'Lexend', sans-serif; 
            font-weight: 800; 
            margin: 0; 
            letter-spacing: -0.5px;
        }
        .login-logo p { 
            color: #64748b; 
            font-size: 0.95rem; 
            margin-top: 0.5rem; 
        }
        .form-control-login {
            height: 50px; 
            border-radius: 8px; 
            border: 1px solid #e2e8f0; 
            background: #f8fafc; 
            padding: 0 1.25rem; 
            width: 100%; 
            transition: all 0.2s ease;
            font-size: 0.95rem;
        }
        .form-control-login:focus {
            border-color: #003893; 
            background: white; 
            box-shadow: 0 0 0 4px rgba(0, 56, 147, 0.1); 
            outline: none;
        }
        .btn-login {
            background: linear-gradient(135deg, #003893, #0056e0); 
            color: white; 
            border: none; 
            height: 50px; 
            border-radius: 8px; 
            font-weight: 600; 
            width: 100%; 
            font-size: 1rem; 
            margin-top: 1.5rem; 
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-login:hover {
            transform: translateY(-2px); 
            box-shadow: 0 8px 15px rgba(0, 56, 147, 0.3); 
            color: white;
        }
        .error-msg { 
            background: #fef2f2; 
            color: #dc2626; 
            border: 1px solid #fecaca;
            border-radius: 8px; 
            padding: 1rem; 
            font-size: 0.875rem; 
            font-weight: 500; 
            display: flex; 
            align-items: center; 
            gap: 0.5rem; 
            margin-bottom: 1.5rem; 
            animation: fadeIn 0.3s ease;
        }
        .validation-error span {
            color: #dc2626;
            font-size: 0.8rem;
            margin-top: 5px;
            display: block;
        }
    </style>
</head>
<body>
    <div class="login-card animate-fade">
        <div class="login-logo">
            <i class="fas fa-bolt"></i>
            <h3>HỆ THỐNG BÁO CÁO</h3>
            <p>Xác thực người dùng nội bộ EVN</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-msg">
                <i class="fas fa-circle-exclamation fa-lg"></i>
                @Model.ErrorMessage
            </div>
        }

        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            
            <div class="mb-3 validation-error">
                <label class="form-label text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">TÊN ĐĂNG NHẬP / TÀI KHOẢN</label>
                <input asp-for="Username" class="form-control-login" placeholder="VD: pckhanh_nq" autocomplete="off" />
                <span asp-validation-for="Username"></span>
            </div>
            
            <div class="mb-4 validation-error">
                <label class="form-label text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">MẬT KHẨU</label>
                <input asp-for="Password" type="password" class="form-control-login" placeholder="Nhập mật khẩu của bạn" />
                <span asp-validation-for="Password"></span>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="rememberMe">
                <label class="form-check-label text-muted" for="rememberMe" style="font-size: 0.9rem; margin-top:2px; font-weight:500;">
                    Duy trì đăng nhập
                </label>
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt me-2"></i> ĐĂNG NHẬP HỆ THỐNG
            </button>
        </form>
    </div>

    <!-- Nhúng Validate Form Client Side -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
