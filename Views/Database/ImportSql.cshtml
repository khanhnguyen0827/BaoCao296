@{
    ViewData["Title"] = "Import SQL Database";
}

<div class="card shadow-sm border-0 mt-3">
    <div class="card-header bg-primary text-white d-flex align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fas fa-database me-2"></i> Cập Nhật Dữ Liệu Bằng File (CSV / SQL)</h5>
    </div>
    <div class="card-body">
        
        @if (ViewBag.TargetIdDv != null)
        {
            <div class="alert alert-info mb-4">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Chế độ:</strong> Nhập dữ liệu riêng cho Đơn vị ID: <strong>@ViewBag.TargetIdDv</strong>. 
                Dữ liệu cũ của đơn vị này sẽ bị ghi đè, các đơn vị khác không bị ảnh hưởng.
            </div>
        }
        
        <div class="alert alert-warning mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Lưu ý:</strong> Khi thực thi tính năng này, hệ thống sẽ tự động cập nhật dữ liệu. 
            <ul>
                <li>Đối với <strong>File Excel (.xlsx)</strong>: Cần có 3 Sheet (Grid 1: Tổng hợp, Grid 2: Chi tiết C3, Grid 3: Chi tiết C8).</li>
                <li>Đối với <strong>File CSV/SQL</strong>: Hệ thống sẽ thực thi lệnh trực tiếp hoặc nạp vào bảng tổng hợp.</li>
            </ul>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-times-circle me-2"></i> @TempData["ErrorMessage"]
                @if (TempData["ErrorDetails"] != null)
                {
                    <hr>
                    <p class="mb-0 small text-break">@TempData["ErrorDetails"]</p>
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-controller="Database" asp-action="ImportSql" method="post" enctype="multipart/form-data">
            @if (ViewBag.TargetIdDv != null)
            {
                <input type="hidden" name="idDv" value="@ViewBag.TargetIdDv" />
            }
            <div class="mb-4">
                <label for="sqlFiles" class="form-label fw-semibold">Chọn các file dữ liệu (.sql, .csv, .txt, .xlsx)</label>
                <input class="form-control form-control-lg" type="file" id="sqlFiles" name="sqlFiles" accept=".sql,.csv,.txt,.xlsx" multiple required>
                <div class="form-text">
                    - <strong>Excel:</strong> Tự động nạp vào cả 3 bảng (Tổng hợp và Chi tiết C3/C8).<br/>
                    - <strong>CSV:</strong> Nhận diện nếu dòng đầu là "ID,ID_DV...".<br/>
                    - <strong>SQL:</strong> Chạy các lệnh phân tách bằng dấu (;).
                </div>
            </div>

            <button type="submit" class="btn btn-primary px-4">
                <i class="fas fa-upload me-2"></i> Bắt Đầu Tải Lên & Thực Thi
            </button>
        </form>
    </div>
</div>
