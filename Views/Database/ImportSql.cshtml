@{
    ViewData["Title"] = "Import SQL Database";
}

<div class="card shadow-sm border-0 mt-3">
    <div class="card-header bg-primary text-white d-flex align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fas fa-database me-2"></i> Cập Nhật Dữ Liệu Bằng File (CSV / SQL)</h5>
    </div>
    <div class="card-body">
        
        <div class="alert alert-warning mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Lưu ý:</strong> Khi thực thi tính năng này, hệ thống sẽ tự động vô hiệu hóa (<code>DISABLE = 1</code>) các dữ liệu cũ của biểu 3 (<code>BC_VP_QD_296_BIEU_3</code>) trước khi nạp dữ liệu mới. Hãy chắc chắn rằng bạn đã sao lưu dữ liệu trước khi thực hiện hoặc chắc chắn file tải lên là chính xác. Hỗ trợ file lệnh SQL hoặc file trích xuất dạng CSV.
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-times-circle me-2"></i> @TempData["ErrorMessage"]
                @if (TempData["ErrorDetails"] != null)
                {
                    <hr>
                    <p class="mb-0 small text-break">@TempData["ErrorDetails"]</p>
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-controller="Database" asp-action="ImportSql" method="post" enctype="multipart/form-data">
            <div class="mb-4">
                <label for="sqlFile" class="form-label fw-semibold">Chọn file dữ liệu (.sql, .csv, .txt)</label>
                <input class="form-control form-control-lg" type="file" id="sqlFile" name="sqlFile" accept=".sql,.csv,.txt" required>
                <div class="form-text">Hệ thống sẽ tự nhận diện định dạng CSV nếu dòng đầu tiên là "ID,ID_DV,COT_1...". Nếu không, hệ thống sẽ chạy như các lệnh SQL phân tách bằng dấu chấm phẩy (;).</div>
            </div>

            <button type="submit" class="btn btn-primary px-4">
                <i class="fas fa-upload me-2"></i> Bắt Đầu Tải Lên & Thực Thi
            </button>
        </form>
    </div>
</div>
